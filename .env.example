# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1

# Database (MySQL)
DATABASE_URL="mysql://root:root@localhost:3306/clearnest"

# JWT
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=7d

# CORS (panel dev + produkcja)
CORS_ORIGINS=http://localhost:5173,https://panel.clearnest.pl,https://clearnest.pl

# Seed (pierwszy admin)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
